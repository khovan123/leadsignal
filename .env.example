# Core services
DATABASE_URL=postgresql://leadsignal:leadsignal@localhost:5432/leadsignal?schema=public
VALKEY_URL=redis://localhost:6379
API_PORT=4000
INTERNAL_API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000
PUBLIC_API_URL=http://localhost:4000/api
PUBLIC_APP_URL=http://localhost:3000

# Generate independently per environment. Never commit real values.
CREDENTIAL_ENCRYPTION_KEY=change-me-to-64-hex-characters
JWT_ACCESS_SECRET=change-me-to-a-random-secret-at-least-32-characters
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_DAYS=30
JWT_ISSUER=leadsignal-api
JWT_AUDIENCE=leadsignal-web

# Private extension login
PASSWORD_AUTH_ENABLED=false
MAX_PRIVATE_USERS=10
EXTENSION_BOOTSTRAP_CODE=

# Worker and optional public collector
WORKER_CONCURRENCY=20
REDDIT_COLLECTION_CONCURRENCY=1
REDDIT_COLLECTOR_INTERVAL_SECONDS=300
REDDIT_CRAWLER_ENABLED=false
REDDIT_SHOW_BROWSER=false
REDDIT_BROWSER_CHANNEL=chrome
# Fallback defaults for sources created before per-source settings existed.
REDDIT_CRAWLER_POSTS_PER_SOURCE=50
REDDIT_CRAWLER_MAX_SCROLLS=20
REDDIT_CRAWLER_MAX_STALL_ROUNDS=4
REDDIT_CRAWLER_NAVIGATION_TIMEOUT_MS=30000
REDDIT_CRAWLER_USER_AGENT=LeadSignalPublicCollector/1.0
REDDIT_CRAWLER_LOCALE=en-US
REDDIT_CRAWLER_TIMEZONE=Asia/Ho_Chi_Minh

# Official provider OAuth applications
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_MODELS_DEFAULT_MODEL=openai/gpt-4.1-mini
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GEMINI_DEFAULT_MODEL=gemini-2.5-flash

# Invitation email
RESEND_API_KEY=
INVITATION_FROM_EMAIL=LeadSignal <noreply@example.com>
