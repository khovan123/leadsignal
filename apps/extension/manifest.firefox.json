{
  "manifest_version": 3,
  "name": "LeadSignal Extension",
  "version": "1.3.1",
  "description": "Device authentication and backend crawler control for LeadSignal.",
  "icons": {
    "48": "icon-firefox.svg",
    "96": "icon-firefox.svg"
  },
  "permissions": ["storage", "cookies", "scripting"],
  "host_permissions": [
    "https://reddit.com/*",
    "https://*.reddit.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "optional_host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "scripts": ["crypto.js", "api.js", "background.js"]
  },
  "content_scripts": [
    {
      "matches": ["http://localhost/*", "http://127.0.0.1/*"],
      "js": ["content-leadsignal.js"],
      "run_at": "document_start"
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "action": {
    "default_title": "Open LeadSignal",
    "default_icon": "icon-firefox.svg",
    "default_popup": "popup.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "leadsignal@local",
      "strict_min_version": "109.0"
    }
  }
}
