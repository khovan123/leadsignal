{
  "manifest_version": 3,
  "name": "LeadSignal Extension",
  "version": "1.1.0",
  "description": "Device authentication and signed Reddit post ingestion for LeadSignal.",
  "icons": {
    "48": "icon-firefox.svg",
    "96": "icon-firefox.svg"
  },
  "permissions": ["activeTab", "storage", "tabs", "scripting"],
  "host_permissions": [
    "https://reddit.com/*",
    "https://*.reddit.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "optional_host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["http://localhost/*", "http://127.0.0.1/*"],
      "js": ["content-leadsignal.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://reddit.com/*", "https://*.reddit.com/*"],
      "js": ["content-reddit.js"],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "action": {
    "default_title": "Open LeadSignal",
    "default_icon": "icon-firefox.svg",
    "default_popup": "popup.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "leadsignal@local",
      "strict_min_version": "109.0"
    }
  }
}
