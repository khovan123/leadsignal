{
  "manifest_version": 3,
  "name": "LeadSignal Extension",
  "version": "1.0.0",
  "description": "Device authentication and signed Reddit post ingestion for LeadSignal.",
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://reddit.com/*",
    "https://*.reddit.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": ["content-leadsignal.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "LeadSignal",
    "default_popup": "popup.html"
  }
}
