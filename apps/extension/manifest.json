{
  "manifest_version": 3,
  "name": "LeadSignal Extension",
  "version": "1.2.0",
  "description": "Device authentication and backend crawler control for LeadSignal.",
  "permissions": ["storage"],
  "host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "optional_host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://localhost/*", "http://127.0.0.1/*"],
      "js": ["content-leadsignal.js"],
      "run_at": "document_start"
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "action": {
    "default_title": "Open LeadSignal",
    "default_popup": "popup.html"
  }
}
